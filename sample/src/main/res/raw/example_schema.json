{
    "display": "wizard",
    "title": "Ejemplo Completo",
    "components": [
        {
            "title": "Datos del Cliente",
            "label": "Datos del Cliente",
            "type": "panel",
            "key": "pageDatos",
            "components": [
                {
                    "label": "Nombre completo",
                    "key": "nombre",
                    "type": "textfield",
                    "input": true,
                    "validate": { "required": true }
                },
                {
                    "label": "DPI / Identificación",
                    "key": "dpi",
                    "type": "textfield",
                    "input": true,
                    "validate": { "required": true }
                }
            ],
            "input": false,
            "tableView": false
        },
        {
            "title": "Documentos",
            "label": "Documentos",
            "type": "panel",
            "key": "pageDocumentos",
            "components": [
                {
                    "label": "Foto de la cámara (modo normal)",
                    "key": "fotoNormal",
                    "type": "file",
                    "input": true,
                    "tableView": false,
                    "storage": "base64",
                    "image": true
                },
                {
                    "label": "DPI — Frente",
                    "key": "dpiFrenteImg",
                    "type": "file",
                    "input": true,
                    "tableView": false,
                    "storage": "base64",
                    "image": true,
                    "scan": true,
                    "validate": { "required": true }
                },
                {
                    "label": "DPI — Reverso",
                    "key": "dpiReversoImg",
                    "type": "file",
                    "input": true,
                    "tableView": false,
                    "storage": "base64",
                    "image": true,
                    "scan": true,
                    "validate": { "required": true }
                },
                {
                    "label": "Comprobante de ingresos",
                    "key": "comprobanteImg",
                    "type": "file",
                    "input": true,
                    "tableView": false,
                    "storage": "base64",
                    "image": true,
                    "uploadOnly": true
                }
            ],
            "input": false,
            "tableView": false
        },
        {
            "title": "Verificación",
            "label": "Verificación",
            "type": "panel",
            "key": "pageVerificacion",
            "components": [
                {
                    "label": "Foto del cliente",
                    "key": "fotoCliente",
                    "type": "file",
                    "input": true,
                    "tableView": false,
                    "storage": "base64",
                    "image": true,
                    "selfie": true,
                    "validate": { "required": true }
                },
                {
                    "label": "Observaciones",
                    "key": "observaciones",
                    "type": "textarea",
                    "input": true,
                    "rows": 3
                }
            ],
            "input": false,
            "tableView": false
        }
    ]
}
